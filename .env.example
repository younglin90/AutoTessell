# Database
DATABASE_URL=postgresql://postgres:postgres@db:5432/tessell

# Redis / Celery
REDIS_URL=redis://redis:6379/0

# AWS S3
S3_BUCKET=auto-tessell-jobs
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# App settings
MESH_PRICE_CENTS=500
MAX_STL_SIZE_BYTES=104857600
MAX_JOBS_PER_USER=2
