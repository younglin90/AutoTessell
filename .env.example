# Copy to .env and fill in real values.
# DEV_MODE=true skips Stripe, S3, and Redis — meshes run in-process with
# pytetwild. Just `pip install -r requirements.txt` and `uvicorn main:app`.

# ── Dev vs prod switch ─────────────────────────────────────────────────────
DEV_MODE=true
DEV_STORAGE_PATH=./dev_storage

# ── Database ──────────────────────────────────────────────────────────────
# Local dev (SQLite, no Docker needed):
DATABASE_URL=sqlite:///./tessell.db
# Docker Compose:
# DATABASE_URL=postgresql://postgres:postgres@db:5432/tessell

# ── Redis / Celery (ignored when DEV_MODE=true) ───────────────────────────
REDIS_URL=redis://redis:6379/0

# ── AWS / S3 (ignored when DEV_MODE=true) ────────────────────────────────
S3_BUCKET=auto-tessell-jobs
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Stripe (ignored when DEV_MODE=true) ──────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── App ──────────────────────────────────────────────────────────────────
MESH_PRICE_CENTS=500
MAX_STL_SIZE_BYTES=104857600
MAX_JOBS_PER_USER=2
CORS_ORIGINS=http://localhost:3000
