; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [header]
;   key=value

config_version=5

[application]

config/name="Auto-Tessell"
config/description="CAD/메쉬 → OpenFOAM polyMesh 자동 생성 도구"
config/version="0.1.0"
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.3", "Forward Plus")
config/icon="res://assets/icon.svg"

[autoload]

WebSocketClient="*res://scripts/websocket_client.gd"
AppState="*res://scripts/app_state.gd"

[display]

window/size/viewport_width=1400
window/size/viewport_height=900
window/size/resizable=true
window/stretch/mode="canvas_items"

[rendering]

renderer/rendering_method="forward_plus"
anti_aliasing/quality/msaa_3d=2
environment/defaults/default_clear_color=Color(0.15, 0.15, 0.18, 1)
